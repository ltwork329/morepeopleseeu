SVAF_TTS_PROVIDER=minimax_intl

# MiniMax 国际版
MINIMAX_API_KEY=replace_with_your_key
MINIMAX_GROUP_ID=replace_with_group_id
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_UPLOAD_ENDPOINT=/v1/files/upload
MINIMAX_VOICE_CLONE_ENDPOINT=/v1/voice_clone
MINIMAX_VOICE_DELETE_ENDPOINT=/v1/delete_voice
MINIMAX_TTS_ENDPOINT=/v1/t2a_v2
MINIMAX_TTS_MODEL=speech-2.5-hd-preview
MINIMAX_VOICE_ID=
MINIMAX_AUDIO_FORMAT=mp3
MINIMAX_SAMPLE_RATE=24000
MINIMAX_TIMEOUT_S=60
